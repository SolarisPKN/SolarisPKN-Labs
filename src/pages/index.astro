---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---
<Layout title="SolarisPKN – Laboratorio de ingeniería transparente">
  <!-- Hero -->
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; flex-direction: column; gap: 1.5rem;">
    <h1 style="font-size: clamp(2rem, 8vw, 4rem); font-family: 'JetBrains Mono', monospace;">
      ⚡ Ingeniería <span style="color: var(--border-cyan);">transparente</span>
    </h1>
    <p style="max-width: 600px; font-size: 1.2rem;">Arquitecturas, firmware, automatización y software. Explorá proyectos abiertos, documentación técnica y herramientas desarrolladas para quienes necesitan llevar sus sistemas más lejos.</p>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="/proyectos" class="glass" style="padding: 0.75rem 1.5rem;">Explorar proyectos</a>
      <a href="/arquitectura" class="glass" style="padding: 0.75rem 1.5rem; border-color: var(--accent-pink);">Ver arquitectura en vivo</a>
    </div>
  </section>

  <!-- Narrativa con scroll: chips ESP32 -->
  <ScrollReveal delay="0.2s">
    <div class="glass" style="margin: 2rem auto; max-width: 900px; text-align: center;">
      <h2>🔧 <span id="chip-counter">0</span> dispositivos simulados</h2>
      <canvas id="chip-canvas" width="800" height="200" style="width: 100%; height: auto; background: #00000030; border-radius: 16px;"></canvas>
      <p style="margin-top: 0.5rem;">Cada chip representa un ESP32 conectado a nuestra plataforma.</p>
    </div>
  </ScrollReveal>

  <!-- Sección de arquitectura que se conecta -->
  <ScrollReveal delay="0.4s">
    <div class="glass" style="margin: 2rem auto; max-width: 900px;">
      <h2>🌐 El ecosistema</h2>
      <div id="simple-arch" style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 1rem; margin: 1rem 0;">
        <div class="glass" style="flex: 1; min-width: 120px;">Web (Astro)</div>
        <div class="glass" style="flex: 1; min-width: 120px;">API (Worker)</div>
        <div class="glass" style="flex: 1; min-width: 120px;">D1 DB</div>
        <div class="glass" style="flex: 1; min-width: 120px;">R2 Firmware</div>
      </div>
      <p>Todo corre gratis en Cloudflare y GitHub. <a href="/arquitectura" style="color: var(--border-cyan);">Diagrama interactivo →</a></p>
    </div>
  </ScrollReveal>

  <!-- Últimos posts / early access teaser -->
  <ScrollReveal delay="0.6s">
    <div class="glass" style="margin: 2rem auto; max-width: 900px;">
      <h2>📡 Early Access (próximamente)</h2>
      <p>Los miembros verán este contenido <strong>30 días antes</strong> que el público.</p>
      <button id="early-bait" class="glass" style="margin-top: 0.5rem; cursor: pointer;">Dejame tu mail</button>
    </div>
  </ScrollReveal>

  <script>
    // Mini animación de contador de chips (simula actividad)
    let count = 0;
    const counterEl = document.getElementById('chip-counter');
    const canvas = document.getElementById('chip-canvas');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let animationId;
      function drawChips(num) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < num; i++) {
          ctx.fillStyle = `hsl(${Date.now() / 20 + i * 30}, 100%, 60%)`;
          ctx.beginPath();
          ctx.arc(20 + (i % 20) * 38, 50 + Math.floor(i / 20) * 50, 12, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = 'white';
          ctx.font = '12px monospace';
          ctx.fillText(`ESP${i}`, 20 + (i % 20) * 38 - 8, 50 + Math.floor(i / 20) * 50 + 4);
        }
      }
      setInterval(() => {
        if (count < 42) count = Math.min(42, count + Math.floor(Math.random() * 3));
        else count = 42;
        counterEl.innerText = count;
        drawChips(count);
      }, 800);
      drawChips(0);
    }

    // Botón temporal para capturar mails (solo simula)
    document.getElementById('early-bait')?.addEventListener('click', () => {
      const email = prompt('📧 Dejame tu correo y te aviso cuando lance Early Access:');
      if (email && email.includes('@')) {
        // Aquí luego conectas con un endpoint o guardas en Google Sheets
        alert('✅ Gracias! Te avisaremos pronto. (demo sin backend)');
        console.log('Email capturado:', email);
      } else if (email) alert('Correo inválido');
    });
  </script>
</Layout>