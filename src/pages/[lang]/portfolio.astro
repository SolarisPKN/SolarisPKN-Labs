---
// src/pages/[lang]/portfolio.astro

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;

import Layout from '../../layouts/Layout.astro';
const t = await import(`../../locales/${lang}/portfolio.json`);
const skills = await import(`../../locales/${lang}/portfolioskills.json`);
const common = await import(`../../locales/${lang}/common.json`);
---

<Layout title="Portfolio - Pablo Marchetti Orayen" lang={lang}>
  <div class="portfolio-container">

    <button id="back-to-top" class="glass back-to-top" aria-label="Volver arriba">⬆️</button>

    <!-- ===== HERO ===== -->
    <section class="hero-portfolio glass">
      <div class="hero-text">
        <h1 class="hero-name">{t.hero.nombre}</h1>
        <div class="aptitudes-mini">
          {t.aptitudesMini.map((aptitud) => <span>{aptitud}</span>)}
        </div>
        <div class="contact-info">
          <p>📧 <a href="mailto:PabloKoutaNya@gmail.com">{t.contacto.email}</a></p>
          <p>📱 {t.contacto.whatsappTexto}<a href="https://wa.me/541170095771">{t.contacto.whatsapp}</a></p>
        </div>
        <div class="buttons-social">
          <a href="https://www.linkedin.com/in/solarispkn" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/linkedin.svg" alt="LinkedIn" /> LinkedIn
          </a>
          <a href="https://www.github.com/SolarisPKN" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/github.svg" alt="GitHub" /> GitHub
          </a>
          <a href="https://www.youtube.com/@SolarisPKN" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/youtube.svg" alt="YouTube" /> YouTube
          </a>
          <a href="/cv.pdf" download class="btn-social download">
            <img src="/images/portfolio/logos/download.svg" alt="CV" />
            {t.botones.descargarCV}
          </a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/portfolio/foto-perfil.webp" alt="Pablo Marchetti Orayen" class="profile-pic" />
      </div>
    </section>

    <!-- ===== SOBRE MI (sin imagen duplicada) ===== -->
    <section class="about-section glass reveal" data-reveal>
      <div class="about-grid">
        <div class="about-left">
          <h2>{t.about.title || t.sobreMi.titulo}</h2>
          <p class="about-intro">{t.about.intro}</p>
          <ul class="about-points">
            {t.about.points.map((point) => <li>✔ {point}</li>)}
          </ul>
        </div>
        <!-- La imagen de perfil ya está en el hero, así que no la repetimos -->
      </div>
    </section>

    <!-- ===== EXPERIENCIA ===== -->
    <section class="experiencia glass reveal" data-reveal>
      <h2>{t.experiencia.titulo}</h2>
      <div class="experiencia-item">
        <h3>{t.experiencia.item1.titulo}</h3>
        <p class="fecha">{t.experiencia.item1.fecha}</p>
        <p>{t.experiencia.item1.texto}</p>
      </div>
      <div class="experiencia-item">
        <h3>{t.experiencia.item2.titulo}</h3>
        <p class="fecha">{t.experiencia.item2.fecha}</p>
        <p>{t.experiencia.item2.texto}</p>
      </div>
      <div class="experiencia-item">
        <h3>{t.experiencia.item3.titulo}</h3>
        <p class="fecha">{t.experiencia.item3.fecha}</p>
        <p>{t.experiencia.item3.texto}</p>
      </div>
    </section>

    <!-- ===== FORMACIÓN ===== -->
    <section class="formacion glass reveal" data-reveal>
      <h2>{t.formacion.titulo}</h2>
      <div class="formacion-item">
        <h3>{t.formacion.curso1.titulo}</h3>
        <p>ID: {t.formacion.curso1.id}</p>
        <ul>
          {t.formacion.curso1.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="formacion-item">
        <h3>{t.formacion.curso2.titulo}</h3>
        <p>ID: {t.formacion.curso2.id}</p>
        <ul>
          {t.formacion.curso2.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <!-- ===== CORE AREAS ===== -->
    <section class="core-areas glass reveal" data-reveal>
      <h2>{t.coreAreasTitle}</h2>
      <div class="core-grid">
        {skills.coreAreas.map((area) => (
          <div class="core-card">
            <div class="core-header">
              <span class="core-icon">{area.icon}</span>
              <h3>{area.title}</h3>
            </div>
            <ul class="core-items">
              {area.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== TECH CAROUSEL ===== -->
    <section class="tech-carousel glass reveal" data-reveal>
      <h2>{t.techCarouselTitle}</h2>
      <div class="carousel-wrapper" id="techCarouselWrapper">
        <div class="carousel-track" id="techCarouselTrack">
          {skills.techIcons.map((tech) => (
            <div class="carousel-item">
              <span class="tech-icon-name">{tech}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CERTIFICACIONES (nuevo sistema) ===== -->
    <section class="certifications glass reveal" data-reveal>
      <h2>{t.certificationsTitle}</h2>
      <div class="cert-controls">
        <input type="text" id="cert-search" class="cert-search" placeholder={t.certificationsSearch || 'Buscar...'} />
        <select id="cert-filter" class="cert-filter">
          <option value="all">{t.certificationsFilter || 'Filtrar por empresa'}</option>
          <!-- Las opciones se llenarán con JS desde los datos -->
        </select>
        <select id="cert-category-filter" class="cert-filter">
          <option value="all">Todas las categorías</option>
          <!-- Las opciones se llenarán con JS desde los datos -->
        </select>
      </div>
      <div class="cert-grid" id="cert-grid">
        <!-- Los certificados se renderizarán con JS desde los datos -->
      </div>
    </section>

    <!-- ===== PHILOSOPHY ===== -->
    <section class="philosophy glass reveal" data-reveal>
      <blockquote class="philosophy-quote">“{t.philosophy}”</blockquote>
    </section>

    <!-- ===== INTERESES Y HOBBIES (al final) ===== -->
    <section class="intereses-hobbies glass reveal" data-reveal>
      <h2>{t.estudios.interesesTitulo}</h2>
      <ul class="intereses-lista">
        {t.estudios.intereses.map((interes) => <li>{interes}</li>)}
      </ul>
    </section>

    <!-- ===== MIND MAP (placeholder) ===== -->
    <section class="mind-map glass reveal" data-reveal>
      <h2>{t.mindMapTitle}</h2>
      <div class="mind-map-placeholder">
        <p>🧠 {t.mindMapPlaceholder}</p>
        <p><small>{t.mindMapSubtext}</small></p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="contact-footer glass reveal" data-reveal>
      <p>📧 <a href="mailto:PabloKoutaNya@gmail.com">{t.contacto.email}</a></p>
      <p>📱 WhatsApp: <a href="https://wa.me/541170095771">{t.contacto.whatsapp}</a></p>
      <a href="/cv.pdf" download class="btn-social download">{t.botones.descargarCV}</a>
      <div class="logos-footer">
        <span>SolarisPKN</span>
      </div>
    </footer>

  </div>

  <script>
    // ===== Back to top =====
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
      window.addEventListener('scroll', () => {
        backToTop.style.display = window.scrollY > 300 ? 'flex' : 'none';
      });
      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // ===== TECH CAROUSEL =====
    (function() {
      const track = document.getElementById('techCarouselTrack');
      const wrapper = document.getElementById('techCarouselWrapper');
      if (!track || !wrapper) return;

      const items = Array.from(track.children);
      items.forEach(item => {
        const clone = item.cloneNode(true);
        track.appendChild(clone);
      });

      let currentTranslateX = 0;
      let speed = 0.5;
      let isPaused = false;
      let isDragging = false;
      let startX = 0;
      let prevTranslateX = 0;
      let animationId = null;

      function setTranslateX(value) {
        currentTranslateX = value;
        track.style.transform = `translateX(${value}px)`;
      }

      function animate() {
        if (isPaused || isDragging) {
          animationId = requestAnimationFrame(animate);
          return;
        }
        currentTranslateX -= speed;
        const maxTranslate = -(track.scrollWidth / 2);
        if (currentTranslateX <= maxTranslate) {
          currentTranslateX = 0;
        }
        setTranslateX(currentTranslateX);
        animationId = requestAnimationFrame(animate);
      }

      wrapper.addEventListener('mousedown', (e) => {
        isDragging = true;
        isPaused = true;
        startX = e.clientX;
        prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      });
      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const diff = e.clientX - startX;
        let newX = prevTranslateX + diff;
        const maxX = 0;
        const minX = -(track.scrollWidth / 2);
        if (newX > maxX) newX = maxX;
        if (newX < minX) newX = minX;
        setTranslateX(newX);
      });
      document.addEventListener('mouseup', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => {
            isPaused = false;
            if (!animationId) animate();
          }, 1000);
        }
      });

      wrapper.addEventListener('touchstart', (e) => {
        isDragging = true;
        isPaused = true;
        startX = e.touches[0].clientX;
        prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      }, { passive: true });
      document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const diff = e.touches[0].clientX - startX;
        let newX = prevTranslateX + diff;
        if (newX > 0) newX = 0;
        const minX = -(track.scrollWidth / 2);
        if (newX < minX) newX = minX;
        setTranslateX(newX);
      }, { passive: true });
      document.addEventListener('touchend', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => {
            isPaused = false;
            if (!animationId) animate();
          }, 1000);
        }
      }, { passive: true });

      wrapper.addEventListener('mouseenter', () => { isPaused = true; });
      wrapper.addEventListener('mouseleave', () => {
        isPaused = false;
        if (!animationId) animate();
      });

      animate();

      window.addEventListener('beforeunload', () => {
        if (animationId) cancelAnimationFrame(animationId);
      });
    })();

    // ===== CERTIFICACIONES (nuevo sistema) =====
    // Se espera que los certificados estén en skills.certificados
    // Si no, usamos los datos de formación del JSON de traducciones.
    // Para simplificar, vamos a construir un array de certificados a partir de los datos de formación.
    const certData = [
      {
        nombre: t.formacion.curso1.titulo || "Administrador de Servidores",
        categoria: "Servidores",
        academia: "DKA Formación",
        imagen: "/img/portfolio/certificados/servidores/dka/administrador-servidores.webp"
      },
      {
        nombre: t.formacion.curso2.titulo || "Desarrollador Front-End",
        categoria: "Desarrollo",
        academia: "Fundación Carlos Slim",
        imagen: "/img/portfolio/certificados/desarrollo/carlos-slim/frontend.webp"
      }
    ];

    // Si existe skills.certificados, lo usamos en su lugar
    if (skills.certificados && skills.certificados.length > 0) {
      // Reemplazar certData con los datos del JSON
      // Pero como no tenemos acceso a skills desde el script (está en el frontmatter), lo pasamos como data-attribute o lo definimos aquí manualmente.
      // Para simplificar, dejamos certData fijo.
    }

    const certGrid = document.getElementById('cert-grid');
    const certSearch = document.getElementById('cert-search');
    const certFilter = document.getElementById('cert-filter');
    const certCategoryFilter = document.getElementById('cert-category-filter');

    function renderCertificados(data) {
      if (!certGrid) return;
      certGrid.innerHTML = '';
      data.forEach(cert => {
        const div = document.createElement('div');
        div.className = 'cert-item';
        div.dataset.nombre = cert.nombre.toLowerCase();
        div.dataset.academia = cert.academia;
        div.dataset.categoria = cert.categoria;
        div.innerHTML = `
          <img src="${cert.imagen}" alt="${cert.nombre}" loading="lazy" />
          <span class="cert-nombre">${cert.nombre}</span>
          <span class="cert-academia">${cert.academia}</span>
          <span class="cert-categoria">${cert.categoria}</span>
        `;
        certGrid.appendChild(div);
      });
    }

    // Llenar filtros
    function populateFilters(data) {
      if (!certFilter || !certCategoryFilter) return;
      const academias = [...new Set(data.map(c => c.academia))];
      const categorias = [...new Set(data.map(c => c.categoria))];

      // Limpiar opciones existentes (excepto la primera)
      certFilter.innerHTML = '<option value="all">' + (t.certificationsFilter || 'Filtrar por empresa') + '</option>';
      academias.forEach(acad => {
        const opt = document.createElement('option');
        opt.value = acad;
        opt.textContent = acad;
        certFilter.appendChild(opt);
      });

      certCategoryFilter.innerHTML = '<option value="all">Todas las categorías</option>';
      categorias.forEach(cat => {
        const opt = document.createElement('option');
        opt.value = cat;
        opt.textContent = cat;
        certCategoryFilter.appendChild(opt);
      });
    }

    function filterCertificados() {
      const searchTerm = (certSearch?.value || '').toLowerCase();
      const academia = certFilter?.value || 'all';
      const categoria = certCategoryFilter?.value || 'all';
      const items = document.querySelectorAll('.cert-item');
      items.forEach(item => {
        const nombre = item.dataset.nombre || '';
        const acad = item.dataset.academia || '';
        const cat = item.dataset.categoria || '';
        const matchSearch = nombre.includes(searchTerm);
        const matchAcademia = academia === 'all' || acad === academia;
        const matchCategoria = categoria === 'all' || cat === categoria;
        item.style.display = (matchSearch && matchAcademia && matchCategoria) ? '' : 'none';
      });
    }

    // Inicializar certificados con los datos
    renderCertificados(certData);
    populateFilters(certData);

    certSearch?.addEventListener('input', filterCertificados);
    certFilter?.addEventListener('change', filterCertificados);
    certCategoryFilter?.addEventListener('change', filterCertificados);
  </script>

  <style>
    /* ===== GENERAL (se mantiene igual) ===== */
    .portfolio-container { max-width: 1200px; margin: 0 auto; padding: 1rem; }
    .back-to-top { position: fixed; bottom: 2rem; right: 2rem; background: var(--glass); border: 1px solid var(--border-cyan); border-radius: 50%; width: 48px; height: 48px; font-size: 1.5rem; cursor: pointer; z-index: 1000; display: none; align-items: center; justify-content: center; transition: all 0.2s; }
    .back-to-top:hover { transform: scale(1.05); border-color: var(--accent-pink); }

    /* ===== HERO ===== */
    .hero-portfolio { display: flex; flex-wrap: wrap; gap: 2rem; align-items: center; justify-content: space-between; padding: 2rem; margin-bottom: 2rem; }
    .hero-text { flex: 2; min-width: 250px; }
    .hero-name { font-size: clamp(2rem, 5vw, 3rem); font-family: 'JetBrains Mono', monospace; color: var(--border-cyan); margin-bottom: 1rem; }
    .aptitudes-mini { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .aptitudes-mini span { background: rgba(0, 255, 204, 0.1); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem; }
    .contact-info p { margin: 0.3rem 0; }
    .contact-info a { color: var(--text-light); text-decoration: none; border-bottom: 1px dashed var(--border-cyan); }
    .buttons-social { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem; }
    .btn-social { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.5rem 1.2rem; border-radius: 40px; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); border: 1px solid var(--border-cyan); color: white; text-decoration: none; transition: 0.2s; font-size: 0.9rem; white-space: nowrap; }
    .btn-social img { width: 20px; height: 20px; display: block; flex-shrink: 0; }
    .btn-social:hover { background: var(--border-cyan); color: #0a0a0a; }
    .hero-image { flex: 1; text-align: center; }
    .profile-pic { width: 200px; height: 200px; object-fit: cover; border-radius: 50%; border: 3px solid var(--border-cyan); box-shadow: 0 0 20px rgba(0, 255, 204, 0.3); }

    /* ===== ABOUT (sin imagen) ===== */
    .about-grid { display: flex; gap: 2rem; }
    .about-left { flex: 1; }
    .about-intro { font-size: 1.1rem; margin-bottom: 1rem; opacity: 0.9; }
    .about-points { list-style: none; padding: 0; columns: 2; }
    .about-points li { margin-bottom: 0.4rem; font-size: 0.95rem; }

    /* ===== CORE AREAS ===== */
    .core-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
    .core-card { background: rgba(0, 0, 0, 0.3); border-radius: 16px; padding: 1.2rem; border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.2s, border-color 0.2s; }
    .core-card:hover { transform: translateY(-4px); border-color: var(--border-cyan); }
    .core-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
    .core-icon { font-size: 1.8rem; }
    .core-header h3 { font-size: 1.1rem; font-family: 'JetBrains Mono', monospace; color: var(--border-cyan); margin: 0; }
    .core-items { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .core-items li { background: rgba(0, 255, 204, 0.06); padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; border: 1px solid rgba(255, 255, 255, 0.03); }

    /* ===== TECH CAROUSEL ===== */
    .tech-carousel { overflow: hidden; padding: 1.5rem; }
    .carousel-wrapper { position: relative; overflow: hidden; cursor: grab; user-select: none; }
    .carousel-wrapper:active { cursor: grabbing; }
    .carousel-track { display: flex; gap: 1.5rem; padding: 0.5rem 0; transition: transform 0.05s linear; will-change: transform; }
    .carousel-item { flex: 0 0 auto; display: flex; align-items: center; justify-content: center; width: 80px; height: 80px; background: rgba(0, 0, 0, 0.3); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.3s, border-color 0.3s; padding: 0.5rem; text-align: center; }
    .carousel-item:hover { transform: scale(1.15) translateY(-4px); border-color: var(--border-cyan); background: rgba(0, 255, 204, 0.05); z-index: 2; }
    .tech-icon-name { font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; color: var(--text-light); word-break: break-word; line-height: 1.2; max-width: 70px; }
    @media (max-width: 600px) { .carousel-item { width: 60px; height: 60px; padding: 0.3rem; } .tech-icon-name { font-size: 0.65rem; } }

    /* ===== CERTIFICACIONES ===== */
    .cert-controls { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
    .cert-search { flex: 2; min-width: 200px; padding: 0.5rem 1rem; border-radius: 40px; background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(255, 255, 255, 0.1); color: var(--text-light); outline: none; }
    .cert-search:focus { border-color: var(--border-cyan); }
    .cert-filter { padding: 0.5rem 1rem; border-radius: 40px; background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(255, 255, 255, 0.1); color: var(--text-light); outline: none; cursor: pointer; }

    .cert-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; }
    .cert-item { background: rgba(0, 0, 0, 0.3); border-radius: 16px; padding: 1rem; text-align: center; border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.2s; }
    .cert-item:hover { transform: translateY(-4px); border-color: var(--border-cyan); }
    .cert-item img { width: 100%; height: 150px; object-fit: cover; border-radius: 12px; margin-bottom: 0.5rem; }
    .cert-nombre { display: block; font-weight: 500; font-size: 0.9rem; }
    .cert-academia, .cert-categoria { display: block; font-size: 0.8rem; opacity: 0.6; }

    /* ===== PHILOSOPHY ===== */
    .philosophy-quote { font-size: 1.2rem; line-height: 1.6; font-style: italic; border-left: 3px solid var(--border-cyan); padding-left: 1.5rem; margin: 0; opacity: 0.9; }

    /* ===== INTERESES ===== */
    .intereses-hobbies ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .intereses-hobbies li { background: rgba(0, 255, 204, 0.06); padding: 0.4rem 1rem; border-radius: 20px; border: 1px solid rgba(255, 255, 255, 0.06); }

    /* ===== MIND MAP ===== */
    .mind-map-placeholder { padding: 1.5rem; text-align: center; background: rgba(0, 0, 0, 0.2); border-radius: 16px; opacity: 0.7; }

    /* ===== FOOTER ===== */
    .contact-footer { text-align: center; padding: 2rem; }
    .contact-footer .btn-social { margin: 0.5rem auto; }
    .logos-footer { display: flex; gap: 1rem; margin-top: 1rem; justify-content: center; font-size: 0.9rem; opacity: 0.5; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .hero-portfolio { flex-direction: column-reverse; text-align: center; }
      .aptitudes-mini { justify-content: center; }
      .buttons-social { justify-content: center; }
      .about-grid { flex-direction: column; text-align: center; }
      .about-points { columns: 1; }
      .core-grid { grid-template-columns: 1fr; }
      .profile-pic { width: 150px; height: 150px; }
      .cert-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    }
  </style>
</Layout>