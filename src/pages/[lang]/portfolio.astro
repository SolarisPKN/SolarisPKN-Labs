---
// src/pages/[lang]/portfolio.astro

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;

import Layout from '../../layouts/Layout.astro';
const t = await import(`../../locales/${lang}/portfolio.json`);
const skills = await import(`../../locales/${lang}/portfolioskills.json`);
const common = await import(`../../locales/${lang}/common.json`);
---

<Layout title="Portfolio - Pablo Marchetti Orayen" lang={lang}>
  <div class="portfolio-container">

    <button id="back-to-top" class="glass back-to-top" aria-label="Volver arriba">⬆️</button>

    <!-- ===== HERO ===== -->
    <section class="hero-portfolio glass">
      <div class="hero-text">
        <h1 class="hero-name">{t.hero.nombre}</h1>
        <div class="aptitudes-mini">
          {t.aptitudesMini.map((aptitud) => <span>{aptitud}</span>)}
        </div>
        <div class="contact-info">
          <p>📧 <a href="mailto:PabloKoutaNya@gmail.com">{t.contacto.email}</a></p>
          <p>📱 {t.contacto.whatsappTexto}<a href="https://wa.me/541170095771">{t.contacto.whatsapp}</a></p>
        </div>
        <div class="buttons-social">
          <a href="https://www.linkedin.com/in/solarispkn" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/linkedin.svg" alt="LinkedIn" /> LinkedIn
          </a>
          <a href="https://www.github.com/SolarisPKN" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/github.svg" alt="GitHub" /> GitHub
          </a>
          <a href="https://www.youtube.com/@SolarisPKN" target="_blank" class="btn-social">
            <img src="/images/portfolio/logos/youtube.svg" alt="YouTube" /> YouTube
          </a>
          <a href="/cv.pdf" download class="btn-social download">
            <img src="/images/portfolio/logos/download.svg" alt="CV" />
            {t.botones.descargarCV}
          </a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/portfolio/foto-perfil.webp" alt="Pablo Marchetti Orayen" class="profile-pic" />
      </div>
    </section>

    <!-- ===== SOBRE MI (sin foto, solo texto) ===== -->
    <section class="about-section glass reveal" data-reveal>
      <h2>{t.about.title || t.sobreMi.titulo}</h2>
      <p class="about-intro">{t.about.intro}</p>
      <ul class="about-points">
        {t.about.points.map((point) => <li>✔ {point}</li>)}
      </ul>
    </section>

    <!-- ===== EXPERIENCIA ===== -->
    <section class="experiencia glass reveal" data-reveal>
      <h2>{t.experiencia.titulo}</h2>
      <div class="experiencia-item">
        <h3>{t.experiencia.item1.titulo}</h3>
        <p class="fecha">{t.experiencia.item1.fecha}</p>
        <p>{t.experiencia.item1.texto}</p>
      </div>
      <div class="experiencia-item">
        <h3>{t.experiencia.item2.titulo}</h3>
        <p class="fecha">{t.experiencia.item2.fecha}</p>
        <p>{t.experiencia.item2.texto}</p>
      </div>
      <div class="experiencia-item">
        <h3>{t.experiencia.item3.titulo}</h3>
        <p class="fecha">{t.experiencia.item3.fecha}</p>
        <p>{t.experiencia.item3.texto}</p>
      </div>
    </section>

    <!-- ===== FORMACIÓN ===== -->
    <section class="formacion glass reveal" data-reveal>
      <h2>{t.formacion.titulo}</h2>
      <div class="formacion-item">
        <h3>{t.formacion.curso1.titulo}</h3>
        <p>ID: {t.formacion.curso1.id}</p>
        <ul>
          {t.formacion.curso1.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="formacion-item">
        <h3>{t.formacion.curso2.titulo}</h3>
        <p>ID: {t.formacion.curso2.id}</p>
        <ul>
          {t.formacion.curso2.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <!-- ===== CORE AREAS ===== -->
    <section class="core-areas glass reveal" data-reveal>
      <h2>{t.coreAreasTitle}</h2>
      <div class="core-grid">
        {skills.coreAreas.map((area) => (
          <div class="core-card">
            <div class="core-header">
              <span class="core-icon">{area.icon}</span>
              <h3>{area.title}</h3>
            </div>
            <ul class="core-items">
              {area.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== TECH CAROUSEL ===== -->
    <section class="tech-carousel glass reveal" data-reveal>
      <h2>{t.techCarouselTitle}</h2>
      <div class="carousel-wrapper" id="techCarouselWrapper">
        <div class="carousel-track" id="techCarouselTrack">
          {skills.techIcons.map((tech) => (
            <div class="carousel-item">
              <span class="tech-icon-name">{tech}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CERTIFICACIONES CON FILTROS MEJORADOS ===== -->
    <section class="certificaciones glass reveal" data-reveal>
      <h2>{t.certificationsTitle}</h2>
      <div class="cert-controls">
        <input type="text" id="cert-search" class="cert-search" placeholder={t.certificationsSearch || 'Buscar...'} />
        
        <select id="cert-filter-categoria" class="cert-filter">
          <option value="all">Todas las categorías</option>
          {[...new Set(skills.certificados.map(c => c.categoria))].map(categoria => (
            <option value={categoria}>{categoria}</option>
          ))}
        </select>

        <select id="cert-filter-subcategoria" class="cert-filter">
          <option value="all">Todas las subcategorías</option>
        </select>

        <select id="cert-filter-academia" class="cert-filter">
          <option value="all">Todas las academias</option>
          {[...new Set(skills.certificados.map(c => c.academia))].map(academia => (
            <option value={academia}>{academia}</option>
          ))}
        </select>

        <button id="cert-clear-filters" class="btn-clear-filters">Limpiar filtros</button>
      </div>
      <div class="cert-grid" id="cert-grid">
        {skills.certificados.map((cert) => (
          <div class="cert-card" 
               data-academia={cert.academia} 
               data-categoria={cert.categoria} 
               data-subcategoria={cert.subcategoria || ''}
               data-nombre={cert.nombre}>
            {cert.imagen && (
              <img src={cert.imagen} alt={cert.nombre} class="cert-img" />
            )}
            <span class="cert-nombre">{cert.nombre}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== PHILOSOPHY ===== -->
    <section class="philosophy glass reveal" data-reveal>
      <blockquote class="philosophy-quote">“{t.philosophy}”</blockquote>
    </section>

    <!-- ===== INTERESES Y HOBBIES (movido al final) ===== -->
    <section class="intereses-hobbies glass reveal" data-reveal>
      <h2>{t.estudios.interesesTitulo}</h2>
      <ul class="intereses-lista">
        {t.estudios.intereses.map((interes) => <li>{interes}</li>)}
      </ul>
    </section>

    <!-- ===== MAPA MENTAL (placeholder) ===== -->
    <section class="mind-map glass reveal" data-reveal>
      <h2>🗺️ {t.mindMapTitle || 'Mapa de habilidades'}</h2>
      <div class="mind-map-placeholder">
        <p>🧠 {t.mindMapPlaceholder || 'Próximamente: mapa mental interactivo de habilidades y tecnologías.'}</p>
        <p><small>{t.mindMapSubtext || 'Este espacio albergará un diagrama de nodos interactivo.'}</small></p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="contact-footer glass reveal" data-reveal>
      <p>📧 <a href="mailto:PabloKoutaNya@gmail.com">{t.contacto.email}</a></p>
      <p>📱 WhatsApp: <a href="https://wa.me/541170095771">{t.contacto.whatsapp}</a></p>
      <a href="/cv.pdf" download class="btn-social download">{t.botones.descargarCV}</a>
      <div class="logos-footer">
        <span>SolarisPKN</span>
      </div>
    </footer>

  </div>

  <script>
    // ===== Back to top =====
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
      window.addEventListener('scroll', () => {
        backToTop.style.display = window.scrollY > 300 ? 'flex' : 'none';
      });
      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // ===== TECH CAROUSEL =====
    (function() {
      const track = document.getElementById('techCarouselTrack');
      const wrapper = document.getElementById('techCarouselWrapper');
      if (!track || !wrapper) return;

      const items = Array.from(track.children);
      items.forEach(item => {
        const clone = item.cloneNode(true);
        track.appendChild(clone);
      });

      let currentTranslateX = 0;
      let speed = 0.5;
      let isPaused = false;
      let isDragging = false;
      let startX = 0;
      let prevTranslateX = 0;
      let animationId = null;

      function setTranslateX(value) {
        currentTranslateX = value;
        track.style.transform = `translateX(${value}px)`;
      }

      function animate() {
        if (isPaused || isDragging) {
          animationId = requestAnimationFrame(animate);
          return;
        }
        currentTranslateX -= speed;
        const maxTranslate = -(track.scrollWidth / 2);
        if (currentTranslateX <= maxTranslate) {
          currentTranslateX = 0;
        }
        setTranslateX(currentTranslateX);
        animationId = requestAnimationFrame(animate);
      }

      wrapper.addEventListener('mousedown', (e) => {
        isDragging = true;
        isPaused = true;
        startX = e.clientX;
        prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      });
      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const diff = e.clientX - startX;
        let newX = prevTranslateX + diff;
        const maxX = 0;
        const minX = -(track.scrollWidth / 2);
        if (newX > maxX) newX = maxX;
        if (newX < minX) newX = minX;
        setTranslateX(newX);
      });
      document.addEventListener('mouseup', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => {
            isPaused = false;
            if (!animationId) animate();
          }, 1000);
        }
      });

      wrapper.addEventListener('touchstart', (e) => {
        isDragging = true;
        isPaused = true;
        startX = e.touches[0].clientX;
        prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      }, { passive: true });
      document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const diff = e.touches[0].clientX - startX;
        let newX = prevTranslateX + diff;
        const maxX = 0;
        const minX = -(track.scrollWidth / 2);
        if (newX > maxX) newX = maxX;
        if (newX < minX) newX = minX;
        setTranslateX(newX);
      }, { passive: true });
      document.addEventListener('touchend', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => {
            isPaused = false;
            if (!animationId) animate();
          }, 1000);
        }
      }, { passive: true });

      wrapper.addEventListener('mouseenter', () => { isPaused = true; });
      wrapper.addEventListener('mouseleave', () => {
        isPaused = false;
        if (!animationId) animate();
      });

      animate();

      window.addEventListener('beforeunload', () => {
        if (animationId) cancelAnimationFrame(animationId);
      });
    })();

    // ===== FILTROS DE CERTIFICACIONES (con subcategoría) =====
    const certSearch = document.getElementById('cert-search');
    const certFilterCategoria = document.getElementById('cert-filter-categoria');
    const certFilterSubcategoria = document.getElementById('cert-filter-subcategoria');
    const certFilterAcademia = document.getElementById('cert-filter-academia');
    const certClearBtn = document.getElementById('cert-clear-filters');
    const certCards = document.querySelectorAll('.cert-card');

    // Función para actualizar las subcategorías disponibles según la categoría seleccionada
    function updateSubcategorias() {
      const categoriaSeleccionada = certFilterCategoria.value;
      // Obtener todas las subcategorías únicas de los certificados que coinciden con la categoría seleccionada
      const subcategorias = new Set();
      const allSubcategorias = new Set();

      certCards.forEach(card => {
        const cat = card.dataset.categoria || '';
        const sub = card.dataset.subcategoria || '';
        allSubcategorias.add(sub);
        if (categoriaSeleccionada === 'all' || cat === categoriaSeleccionada) {
          if (sub) subcategorias.add(sub);
        }
      });

      // Limpiar y llenar el select de subcategorías
      certFilterSubcategoria.innerHTML = '<option value="all">Todas las subcategorías</option>';
      // Si no hay categoría seleccionada o es 'all', mostrar todas las subcategorías
      const subList = categoriaSeleccionada === 'all' ? allSubcategorias : subcategorias;
      [...subList].sort().forEach(sub => {
        if (sub) {
          const option = document.createElement('option');
          option.value = sub;
          option.textContent = sub;
          certFilterSubcategoria.appendChild(option);
        }
      });
    }

    function filterCerts() {
      const searchTerm = (certSearch?.value || '').toLowerCase();
      const categoria = certFilterCategoria?.value || 'all';
      const subcategoria = certFilterSubcategoria?.value || 'all';
      const academia = certFilterAcademia?.value || 'all';

      certCards.forEach(card => {
        const nombre = (card.dataset.nombre || '').toLowerCase();
        const cardCategoria = card.dataset.categoria || '';
        const cardSubcategoria = card.dataset.subcategoria || '';
        const cardAcademia = card.dataset.academia || '';

        const matchSearch = nombre.includes(searchTerm);
        const matchCategoria = categoria === 'all' || cardCategoria === categoria;
        const matchSubcategoria = subcategoria === 'all' || cardSubcategoria === subcategoria;
        const matchAcademia = academia === 'all' || cardAcademia === academia;

        card.style.display = (matchSearch && matchCategoria && matchSubcategoria && matchAcademia) ? 'flex' : 'none';
      });
    }

    // Eventos de filtros
    certSearch?.addEventListener('input', filterCerts);
    certFilterCategoria?.addEventListener('change', () => {
      updateSubcategorias();
      filterCerts();
    });
    certFilterSubcategoria?.addEventListener('change', filterCerts);
    certFilterAcademia?.addEventListener('change', filterCerts);

    // Botón limpiar filtros
    certClearBtn?.addEventListener('click', () => {
      certSearch.value = '';
      certFilterCategoria.value = 'all';
      certFilterAcademia.value = 'all';
      // Resetear subcategorías
      updateSubcategorias();
      certFilterSubcategoria.value = 'all';
      filterCerts();
    });

    // Inicializar subcategorías al cargar
    updateSubcategorias();
  </script>

  <style>
    .portfolio-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem;
    }

    .back-to-top {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: var(--glass);
      border: 1px solid var(--border-cyan);
      border-radius: 50%;
      width: 48px;
      height: 48px;
      font-size: 1.5rem;
      cursor: pointer;
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .back-to-top:hover {
      transform: scale(1.05);
      border-color: var(--accent-pink);
    }

    /* HERO */
    .hero-portfolio {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;
      justify-content: space-between;
      padding: 2rem;
      margin-bottom: 2rem;
    }
    .hero-text {
      flex: 2;
      min-width: 250px;
    }
    .hero-name {
      font-size: clamp(2rem, 5vw, 3rem);
      font-family: 'JetBrains Mono', monospace;
      color: var(--border-cyan);
      margin-bottom: 1rem;
    }
    .aptitudes-mini {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .aptitudes-mini span {
      background: rgba(0, 255, 204, 0.1);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.85rem;
    }
    .contact-info p {
      margin: 0.3rem 0;
    }
    .contact-info a {
      color: var(--text-light);
      text-decoration: none;
      border-bottom: 1px dashed var(--border-cyan);
    }
    .buttons-social {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .btn-social {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.5rem 1.2rem;
      border-radius: 40px;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      border: 1px solid var(--border-cyan);
      color: white;
      text-decoration: none;
      transition: 0.2s;
      font-size: 0.9rem;
      white-space: nowrap;
    }
    .btn-social img {
      width: 20px;
      height: 20px;
      display: block;
      flex-shrink: 0;
    }
    .btn-social:hover {
      background: var(--border-cyan);
      color: #0a0a0a;
    }
    .hero-image {
      flex: 1;
      text-align: center;
    }
    .profile-pic {
      width: 200px;
      height: 200px;
      object-fit: cover;
      border-radius: 50%;
      border: 3px solid var(--border-cyan);
      box-shadow: 0 0 20px rgba(0, 255, 204, 0.3);
    }

    /* ABOUT (sin foto) */
    .about-section {
      padding: 1.5rem;
    }
    .about-intro {
      font-size: 1.1rem;
      margin-bottom: 1rem;
      opacity: 0.9;
    }
    .about-points {
      list-style: none;
      padding: 0;
      columns: 2;
    }
    .about-points li {
      margin-bottom: 0.4rem;
      font-size: 0.95rem;
    }

    /* SECCIONES GENERALES */
    section {
      margin-bottom: 2rem;
      padding: 1.5rem;
    }
    h2 {
      font-size: 1.8rem;
      border-left: 4px solid var(--border-cyan);
      padding-left: 1rem;
      margin-bottom: 1rem;
    }
    .fecha {
      font-family: monospace;
      color: var(--border-cyan);
      margin: 0.2rem 0;
    }
    .experiencia-item, .formacion-item {
      margin-bottom: 1.5rem;
    }
    .formacion-item ul {
      padding-left: 1.5rem;
    }

    /* CORE AREAS */
    .core-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.5rem;
    }
    .core-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 16px;
      padding: 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.06);
      transition: transform 0.2s, border-color 0.2s;
    }
    .core-card:hover {
      transform: translateY(-4px);
      border-color: var(--border-cyan);
    }
    .core-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }
    .core-icon {
      font-size: 1.8rem;
    }
    .core-header h3 {
      font-size: 1.1rem;
      font-family: 'JetBrains Mono', monospace;
      color: var(--border-cyan);
      margin: 0;
    }
    .core-items {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }
    .core-items li {
      background: rgba(0, 255, 204, 0.06);
      padding: 0.2rem 0.6rem;
      border-radius: 12px;
      font-size: 0.8rem;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }

    /* TECH CAROUSEL */
    .tech-carousel {
      overflow: hidden;
      padding: 1.5rem;
    }
    .carousel-wrapper {
      position: relative;
      overflow: hidden;
      cursor: grab;
      user-select: none;
    }
    .carousel-wrapper:active {
      cursor: grabbing;
    }
    .carousel-track {
      display: flex;
      gap: 1.5rem;
      padding: 0.5rem 0;
      transition: transform 0.05s linear;
      will-change: transform;
    }
    .carousel-item {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 80px;
      height: 80px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      transition: transform 0.3s, border-color 0.3s;
      padding: 0.5rem;
      text-align: center;
    }
    .carousel-item:hover {
      transform: scale(1.15) translateY(-4px);
      border-color: var(--border-cyan);
      background: rgba(0, 255, 204, 0.05);
      z-index: 2;
    }
    .tech-icon-name {
      font-size: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      color: var(--text-light);
      word-break: break-word;
      line-height: 1.2;
      max-width: 70px;
    }
    @media (max-width: 600px) {
      .carousel-item {
        width: 60px;
        height: 60px;
        padding: 0.3rem;
      }
      .tech-icon-name {
        font-size: 0.65rem;
      }
    }

    /* CERTIFICACIONES */
    .cert-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-bottom: 1.5rem;
      align-items: center;
    }
    .cert-search {
      flex: 2;
      min-width: 180px;
      padding: 0.5rem 1rem;
      border-radius: 40px;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--text-light);
      outline: none;
      font-size: 0.9rem;
    }
    .cert-search:focus {
      border-color: var(--border-cyan);
    }
    .cert-filter {
      padding: 0.5rem 1rem;
      border-radius: 40px;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--text-light);
      outline: none;
      cursor: pointer;
      font-size: 0.85rem;
      min-width: 140px;
    }
    .cert-filter:focus {
      border-color: var(--border-cyan);
    }
    .btn-clear-filters {
      padding: 0.5rem 1.2rem;
      border-radius: 40px;
      background: rgba(255, 121, 198, 0.15);
      border: 1px solid var(--accent-pink);
      color: var(--accent-pink);
      cursor: pointer;
      font-size: 0.85rem;
      transition: all 0.2s;
    }
