---
// src/pages/[lang]/security.astro
// Página de Política de Seguridad bilingüe

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;

import Layout from '../../layouts/Layout.astro';
import '../../styles/security.css'; // 🎨 Estilos separados

// Cargar traducciones
const t = await import(`../../locales/${lang}/security.json`);
const common = await import(`../../locales/${lang}/common.json`);
---

<Layout title={t.titulo} lang={lang}>
  <main class="security-container">
    <h1 class="security-title">🔒 {t.encabezado}</h1>
    <p class="security-date"><strong>{t.actualizacion}</strong> {t.fecha}</p>

    <!-- Reporte -->
    <h2>📬 {t.reporte.titulo}</h2>
    <p>{t.reporte.descripcion}</p>
    <div class="security-contact-box">
      <strong>📧 <a href="mailto:seguridad@solarispkn.com.ar">seguridad@solarispkn.com.ar</a></strong>
    </div>
    <p>{t.reporte.requisitosIntro}</p>
    <ul>
      {t.reporte.requisitos.map((item) => <li>{item}</li>)}
    </ul>
    <p>{t.reporte.nota}</p>

    <hr />

    <!-- Pruebas -->
    <h2>🛡️ {t.pruebas.titulo}</h2>
    <p>{t.pruebas.descripcion}</p>
    <p>{t.pruebas.solicitudIntro}</p>
    <ul>
      {t.pruebas.solicitudes.map((item) => <li>{item}</li>)}
    </ul>

    <h3>🚫 {t.pruebas.noPermitidasTitulo}</h3>
    <p>{t.pruebas.noPermitidasIntro}</p>
    <ul>
      {t.pruebas.noPermitidas.map((item) => <li>{item}</li>)}
    </ul>
    <p>{t.pruebas.aviso}</p>

    <hr />

    <!-- Divulgación -->
    <h2>📢 {t.divulgacion.titulo}</h2>
    <p>{t.divulgacion.descripcion}</p>
    <p>{t.divulgacion.tiempo}</p>
    <p>{t.divulgacion.evaluacionIntro}</p>
    <ul>
      {t.divulgacion.evaluacion.map((item) => <li>{item}</li>)}
    </ul>
    <p>{t.divulgacion.nota}</p>
    <p>{t.divulgacion.coordinacion}</p>

    <hr />

    <!-- Reconocimiento -->
    <h2>🏆 {t.reconocimiento.titulo}</h2>
    <p>{t.reconocimiento.descripcion}</p>
    <ul>
      {t.reconocimiento.condiciones.map((item) => <li>{item}</li>)}
    </ul>

    <hr />

    <!-- Alcance -->
    <h2>🎯 {t.alcance.titulo}</h2>
    <p>{t.alcance.descripcion}</p>
    <p>{t.alcance.otras}</p>

    <hr />

    <!-- Contacto -->
    <h2>📧 {t.contacto.titulo}</h2>
    <div class="security-contact-box">
      <strong>Correo de seguridad:</strong> <a href="mailto:seguridad@solarispkn.com.ar">seguridad@solarispkn.com.ar</a>
    </div>
    <p>{t.contacto.pgp}</p>

    <footer class="security-footer">
      <p>
        <a href={`/${lang}`}>← {common.volverInicio}</a> &bull;
        <a href="/es/">{common.esp}</a> &bull;
        <a href="/en/">{common.eng}</a>
      </p>
      <p>SolarisPKN Labs &bull; <a href="https://labs.solarispkn.com.ar">labs.solarispkn.com.ar</a></p>
    </footer>
  </main>
</Layout>