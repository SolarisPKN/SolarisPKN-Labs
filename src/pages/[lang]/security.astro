---
// src/pages/[lang]/security.astro
export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;

// Cargar traducciones
const t = await import(`../../locales/${lang}/security.json`);
const common = await import(`../../locales/${lang}/common.json`);

import Layout from '../../layouts/Layout.astro';
---

<Layout title={t.titulo} lang={lang}>
  <main style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; color: #e0e0e0;">
    <h1 style="font-size: 2.2rem; border-bottom: 3px solid var(--border-cyan, #0ea5e9); padding-bottom: 0.75rem; color: #ffffff;">
      🔒 {t.titulo}
    </h1>
    <p style="color: #a0a0a0; margin-bottom: 2rem;"><strong>Última actualización:</strong> {t.fecha}</p>

    <!-- ===== REPORTE ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">📬 {t.reporte.titulo}</h2>
    <p>{t.reporte.descripcion}</p>
    <div style="background: rgba(14, 165, 233, 0.15); border-left: 4px solid var(--border-cyan, #0ea5e9); padding: 1rem 1.5rem; border-radius: 8px; margin: 1.5rem 0;">
      <strong style="color: #ffffff;">📧 <a href="mailto:seguridad@solarispkn.com.ar" style="color: var(--border-cyan, #0ea5e9); text-decoration: none;">seguridad@solarispkn.com.ar</a></strong>
    </div>
    <p>{t.reporte.requisitos}</p>
    <ul style="color: #d0d0d0; padding-left: 1.5rem;">
      {t.reporte.lista.map(item => <li>{item}</li>)}
    </ul>

    <!-- ===== POLÍTICA DE PRUEBAS ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">🛡️ {t.pruebas.titulo}</h2>
    <p>{t.pruebas.descripcion}</p>
    <p>{t.pruebas.solicitud}</p>
    <ul style="color: #d0d0d0; padding-left: 1.5rem;">
      {t.pruebas.lista.map(item => <li>{item}</li>)}
    </ul>

    <h3 style="color: #ffffff; margin-top: 1.5rem;">🚫 {t.pruebas.noPermitidas.titulo}</h3>
    <p>{t.pruebas.noPermitidas.descripcion}</p>
    <ul style="color: #d0d0d0; padding-left: 1.5rem;">
      {t.pruebas.noPermitidas.lista.map(item => <li>{item}</li>)}
    </ul>

    <!-- ===== DIVULGACIÓN ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">📢 {t.divulgacion.titulo}</h2>
    <p>{t.divulgacion.descripcion}</p>
    <p>{t.divulgacion.recomendacion}</p>
    <p>{t.divulgacion.evaluacion}</p>
    <ul style="color: #d0d0d0; padding-left: 1.5rem;">
      {t.divulgacion.lista.map(item => <li>{item}</li>)}
    </ul>

    <!-- ===== RECONOCIMIENTO ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">🏆 {t.reconocimiento.titulo}</h2>
    <p>{t.reconocimiento.descripcion}</p>
    <ul style="color: #d0d0d0; padding-left: 1.5rem;">
      {t.reconocimiento.lista.map(item => <li>{item}</li>)}
    </ul>

    <!-- ===== ALCANCE ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">🎯 {t.alcance.titulo}</h2>
    <p>{t.alcance.descripcion}</p>

    <!-- ===== CONTACTO ===== -->
    <h2 style="color: #ffffff; margin-top: 2.5rem;">📧 {t.contacto.titulo}</h2>
    <div style="background: rgba(14, 165, 233, 0.15); border-left: 4px solid var(--border-cyan, #0ea5e9); padding: 1rem 1.5rem; border-radius: 8px; margin: 1rem 0;">
      <strong style="color: #ffffff;">Correo de seguridad:</strong> <a href="mailto:seguridad@solarispkn.com.ar" style="color: var(--border-cyan, #0ea5e9); text-decoration: none;">seguridad@solarispkn.com.ar</a>
    </div>
    <p style="color: #a0a0a0;">{t.contacto.recomendacion}</p>

    <!-- ===== FOOTER ===== -->
    <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 3rem 0 1.5rem;" />
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.9rem; color: #888;">
      <a href="/" style="color: #888; text-decoration: none;">← Volver al inicio</a>
      <a href="/es/security" style="color: #888; text-decoration: none;">Español</a>
      <a href="/en/security" style="color: #888; text-decoration: none;">English</a>
      <span style="color: #555;">SolarisPKN Labs</span>
    </div>
  </main>
</Layout>