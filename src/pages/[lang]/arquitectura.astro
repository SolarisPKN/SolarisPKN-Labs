---
// src/pages/[lang]/arquitectura.astro
export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
import Layout from '../../layouts/Layout.astro';
const t = await import(`../../locales/${lang}/arquitectura.json`);
---

<Layout title={t.titulo} lang={lang}>
  <div class="glass" style="margin: 2rem auto; max-width: 1100px; padding: 2rem;">
    <h1>🔍 {t.titulo}</h1>
    <p>{t.descripcion}</p>
    <div class="mermaid-wrapper" style="width: 100%; overflow: auto; margin-top: 2rem;">
      <pre class="mermaid" style="background: transparent; min-width: 600px;">
        graph TD
          A["🌞 solarispkn.github.io<br>Astro + GitHub Pages"] -->|Fetch API| B["⚡ Cloudflare Worker<br>solarispkn-api"]
          B --> C["(🗄️ D1 Database)<br>users, posts, entitlements"]
          B --> D["(⚡ KV Cache)<br>sesiones y early access"]
          B --> E["(📦 R2 Storage)<br>firmware premium"]
          C --> F["📋 Tablas: users, products, licenses"]
          E --> G["🔒 Firmware ESP32 Low Power"]
          style A fill:#1E1E2F,stroke:#00FFCC,stroke-width:2px
          style B fill:#1E1E2F,stroke:#FF79C6,stroke-width:2px
          style C fill:#1E1E2F,stroke:#50FA7B,stroke-width:2px
          style D fill:#1E1E2F,stroke:#50FA7B,stroke-width:2px
          style E fill:#1E1E2F,stroke:#FFB86C,stroke-width:2px
      </pre>
    </div>
    <p style="margin-top: 1rem;">⚡ <strong>{t.notaInteractiva}</strong></p>
  </div>

  <!-- ===== SCRIPT OPTIMIZADO ===== -->
  <script>
    let mermaidInitialized = false;

    async function initMermaid() {
      // Evitar reinicializaciones innecesarias
      if (mermaidInitialized) return;
      mermaidInitialized = true;

      try {
        // Importar Mermaid solo cuando sea necesario (carga diferida)
        const { default: mermaid } = await import(
          /* webpackChunkName: "mermaid" */
          'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs'
        );

        // Inicializar Mermaid con la configuración adecuada
        mermaid.initialize({
          startOnLoad: false,
          theme: 'dark',
          themeVariables: {
            background: '#0B0B10',
            primaryColor: '#1E1E2F',
            primaryBorderColor: '#00FFCC',
            lineColor: '#00FFCC',
            tertiaryColor: '#1E1E2F',
          },
        });

        // Buscar todos los elementos con clase 'mermaid'
        const elements = document.querySelectorAll('.mermaid');
        if (elements.length > 0) {
          await mermaid.run({ nodes: elements });
          console.log('✅ Mermaid inicializado correctamente');
        }
      } catch (error) {
        console.warn('⚠️ Error al cargar Mermaid:', error);
        // Fallback: mostrar el código en texto plano
        const pre = document.querySelector('.mermaid');
        if (pre) {
          pre.style.display = 'block';
          pre.style.whiteSpace = 'pre-wrap';
          pre.textContent = pre.textContent || 'Diagrama no disponible';
        }
      }
    }

    // ===== ESTRATEGIA DE CARGA =====
    // 1. Intentar cargar cuando el navegador esté inactivo (prioridad baja)
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => initMermaid(), { timeout: 3000 });
    } else {
      // 2. Fallback: cargar después de que la página esté completamente cargada
      document.addEventListener('load', initMermaid, { once: true });
    }

    // 3. También en cada navegación con View Transitions (solo si no se ha inicializado)
    document.addEventListener('astro:page-load', () => {
      if (!mermaidInitialized) {
        initMermaid();
      } else {
        // Si ya está inicializado, solo reiniciamos si hay nuevos nodos
        const elements = document.querySelectorAll('.mermaid:not([data-processed])');
        if (elements.length > 0) {
          // Reimportar Mermaid y procesar los nuevos nodos
          import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs')
            .then(({ default: mermaid }) => {
              mermaid.run({ nodes: elements });
            })
            .catch(err => console.warn('Error al procesar nuevos nodos Mermaid', err));
        }
      }
    });
  </script>
</Layout>