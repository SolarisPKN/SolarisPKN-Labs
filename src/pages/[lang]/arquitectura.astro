---
// src/pages/[lang]/arquitectura.astro
export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
import Layout from '../../layouts/Layout.astro';
const t = await import(`../../locales/${lang}/arquitectura.json`);
---

<Layout title={t.titulo} lang={lang}>
  <div class="glass" style="margin: 2rem auto; max-width: 1100px; padding: 2rem;">
    <h1>🔍 {t.titulo}</h1>
    <p>{t.descripcion}</p>
    <div class="mermaid-wrapper" style="width: 100%; overflow: auto; margin-top: 2rem;">
      <pre class="mermaid" style="background: transparent; min-width: 600px;">
        graph TD
          A["🌞 solarispkn.github.io<br>Astro + GitHub Pages"] -->|Fetch API| B["⚡ Cloudflare Worker<br>solarispkn-api"]
          B --> C["(🗄️ D1 Database)<br>users, posts, entitlements"]
          B --> D["(⚡ KV Cache)<br>sesiones y early access"]
          B --> E["(📦 R2 Storage)<br>firmware premium"]
          C --> F["📋 Tablas: users, products, licenses"]
          E --> G["🔒 Firmware ESP32 Low Power"]
          style A fill:#1E1E2F,stroke:#00FFCC,stroke-width:2px
          style B fill:#1E1E2F,stroke:#FF79C6,stroke-width:2px
          style C fill:#1E1E2F,stroke:#50FA7B,stroke-width:2px
          style D fill:#1E1E2F,stroke:#50FA7B,stroke-width:2px
          style E fill:#1E1E2F,stroke:#FFB86C,stroke-width:2px
      </pre>
    </div>
    <p style="margin-top: 1rem;">⚡ <strong>{t.notaInteractiva}</strong></p>
  </div>

  <script>
    // Inicializar Mermaid después de cada navegación
    async function initMermaid() {
      // Si ya existe, limpiar versiones anteriores
      const mermaidPre = document.querySelector('.mermaid');
      if (!mermaidPre) return;

      // Eliminar posibles instancias previas de Mermaid
      const wrapper = mermaidPre.parentElement;
      const clone = mermaidPre.cloneNode(true);
      wrapper.replaceChild(clone, mermaidPre);

      // Importar y ejecutar Mermaid
      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs');
      mermaid.initialize({ startOnLoad: true, theme: 'dark', themeVariables: { background: '#0B0B10' } });
      await mermaid.run({ nodes: [clone] });
    }

    // Ejecutar al cargar la página y en cada navegación
    document.addEventListener('astro:page-load', initMermaid);
  </script>
</Layout>