---
// src/pages/[lang]/index.astro
export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;

import Layout from '../../layouts/Layout.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';

// Cargar las traducciones específicas de home y common
const t = await import(`../../locales/${lang}/home.json`);
const common = await import(`../../locales/${lang}/common.json`);
---

<Layout title={t.hero.titulo} lang={lang}>
  <!-- Hero -->
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; flex-direction: column; gap: 1.5rem;">
    <h1 style="font-size: clamp(2rem, 8vw, 4rem); font-family: 'JetBrains Mono', monospace;">
      ⚡ {t.hero.titulo}
    </h1>
    <p style="max-width: 600px; font-size: 1.2rem;">{t.hero.descripcion}</p>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href={`/${lang}/under-construction`} class="glass" style="padding: 0.75rem 1.5rem;">{t.botones.proyectos}</a>
      <a href={`/${lang}/arquitectura`} class="glass" style="padding: 0.75rem 1.5rem; border-color: var(--accent-pink);">{t.botones.arquitectura}</a>
    </div>
  </section>

  <!-- Narrativa con scroll: chips ESP32 -->
  <ScrollReveal delay="0.2s">
      <div class="glass" style="margin: 2rem auto; max-width: 900px; text-align: center;">
      <h2>🔧 <span id="chip-counter">0</span> {t.chipTitulo}</h2>
      <canvas id="chip-canvas" width="800" height="200" style="width: 100%; height: auto; background: #00000030; border-radius: 16px;"></canvas>
      <p style="margin-top: 0.5rem;">{t.chipDescripcion}</p>
     </div>
  </ScrollReveal>

  <!-- Sección de arquitectura que se conecta -->
  <ScrollReveal delay="0.4s">
    <div class="glass" style="margin: 2rem auto; max-width: 900px;">
      <h2>{t.ecosistema.titulo}</h2>
      <div id="simple-arch" style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 1rem; margin: 1rem 0;">
        <div class="glass" style="flex: 1; min-width: 120px;">{t.ecosistema.web}</div>
        <div class="glass" style="flex: 1; min-width: 120px;">{t.ecosistema.api}</div>
        <div class="glass" style="flex: 1; min-width: 120px;">{t.ecosistema.db}</div>
        <div class="glass" style="flex: 1; min-width: 120px;">{t.ecosistema.r2}</div>
      </div>
      <p>{t.ecosistema.texto} <a href={`/${lang}/arquitectura`} style="color: var(--border-cyan);">{t.ecosistema.diagrama}</a></p>
    </div>
  </ScrollReveal>

  <!-- Últimos posts / early access teaser -->
  <ScrollReveal delay="0.6s">
    <div class="glass" style="margin: 2rem auto; max-width: 900px;">
      <h2>{t.early.titulo}</h2>
      <p>{t.early.descripcion}</p>
      <button id="early-bait" class="glass" style="margin-top: 0.5rem; cursor: pointer;">{t.early.boton}</button>
    </div>
  </ScrollReveal>

<script>
  // Mini animación de contador de chips (simula actividad)
  let count = 0;
  const counterEl = document.getElementById('chip-counter');
  const canvas = document.getElementById('chip-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    function drawChips(num) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < num; i++) {
        ctx.fillStyle = `hsl(${Date.now() / 20 + i * 30}, 100%, 60%)`;
        ctx.beginPath();
        ctx.arc(20 + (i % 20) * 38, 50 + Math.floor(i / 20) * 50, 12, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = 'white';
        ctx.font = '12px monospace';
        ctx.fillText(`ESP${i}`, 20 + (i % 20) * 38 - 8, 50 + Math.floor(i / 20) * 50 + 4);
      }
    }
    setInterval(() => {
      if (count < 42) count = Math.min(42, count + Math.floor(Math.random() * 3));
      else count = 42;
      counterEl.innerText = count;
      drawChips(count);
    }, 800);
    drawChips(0);
  }

  // Botón de early access con textos traducidos (usando las variables insertadas desde Astro)
  const emailMessages = {
    message: JSON.parse('{"v":"${t.emailPrompt.message}"}').v,
    success: JSON.parse('{"v":"${t.emailPrompt.success}"}').v,
    invalid: JSON.parse('{"v":"${t.emailPrompt.invalid}"}').v
  };
  document.getElementById('early-bait')?.addEventListener('click', () => {
    const email = prompt(emailMessages.message);
    if (email && email.includes('@')) {
      alert(emailMessages.success);
      console.log('Email capturado:', email);
    } else if (email) alert(emailMessages.invalid);
  });
</script>
</Layout>