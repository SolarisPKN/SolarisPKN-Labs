---
// src/layouts/Layout.astro
import SEO from '@components/SEO.astro';
import { ViewTransitions } from 'astro:transitions';
import "@styles/global.css";

export interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
  image?: string;
  schema?: 'person' | 'website' | 'article';
  canonical?: string;
}

const {
  title,
  description = 'SolarisPKN - Laboratorio transparente de ingeniería',
  lang = 'es',
  image = '/social.jpg',
  schema = 'website',
  canonical,
} = Astro.props;

// Cargar traducciones
const common = await import(`../locales/${lang}/common.json`);

// Cargar banderas desde src/assets/flags/
const flagModules = import.meta.glob('/src/assets/flags/*.svg', {
  eager: true,
  as: 'url',
});

const getFlagSrc = (langCode: string): string => {
  const key = `/src/assets/flags/${langCode}.svg`;
  return flagModules[key] || `/images/flags/${langCode}.svg`;
};

const pathWithoutLang = Astro.url.pathname.replace(/^\/[a-z]{2}\//, '/');
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      canonical={canonical || Astro.url.pathname}
      locale={lang === 'es' ? 'es_AR' : 'en_US'}
      schema={schema}
      author="Pablo Marchetti Orayen"
      jobTitle="IT Infrastructure Specialist"
    />

    <ViewTransitions />

    <!-- ===== FUENTES LOCALES (optimizadas) ===== -->
    <!-- Preload de las fuentes críticas -->
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono.woff2" as="font" type="font/woff2" crossorigin />

    <style>
      /* Declaración de @font-face para usar fuentes locales */
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/inter.woff2') format('woff2-variations');
      }

      @font-face {
        font-family: 'JetBrains Mono';
        font-style: normal;
        font-weight: 400 600;
        font-display: swap;
        src: url('/fonts/jetbrains-mono.woff2') format('woff2-variations');
      }

      /* Estilos de respaldo (opcional) */
      .fallback-font {
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      }
    </style>

    <!-- ===== RECURSOS EXTERNOS (solo si es necesario) ===== -->
    <!-- Si aún quieres usar Google Fonts como fallback, mantén solo un enlace -->
    <!-- <link rel="preconnect" href="https://fonts.googleapis.com" /> -->
    <!-- <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /> -->
  </head>

  <body>
    <!-- SKIP TO CONTENT -->
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <!-- HEADER -->
    <header
      class="glass"
      style="position: sticky; top: 1rem; margin: 1rem; z-index: 100; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;"
    >
      <div style="font-weight: bold; font-family: 'JetBrains Mono', monospace; display: flex; align-items: center; gap: 0.5rem;">
        <img src="/favicon.svg" alt="SolarisPKN Labs" width="24" height="24" loading="eager" fetchpriority="high" />
        SolarisPKN-Labs
      </div>

      <nav style="display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;">
        <a href={`/${lang}/`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.inicio}</a>
        <a href={`/${lang}/blog`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.blog}</a>
        <a href={`/${lang}/under-construction`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.proyectos}</a>
        <a href={`/${lang}/arquitectura`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.arquitectura}</a>
        <a href={`/${lang}/portfolio`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.portfolio}</a>
        <a href={`/${lang}/under-construction`} style="color: var(--accent-pink);">{common.nav.miCuenta}</a>

        <!-- SELECTOR DE IDIOMA -->
        <div class="language-dropdown" style="position: relative; margin-left: 0.5rem;">
          <div class="language-selector">
            <button id="lang-btn" class="lang-btn" aria-haspopup="true" aria-expanded="false">
              <img
                src={getFlagSrc(lang)}
                alt={lang === 'es' ? 'Español' : 'English'}
                width="20"
                height="15"
                loading="lazy"
              />
              <span>{lang === 'es' ? 'Español' : 'English'}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <ul id="lang-dropdown" class="lang-dropdown" role="menu" aria-labelledby="lang-btn">
              <li role="menuitem">
                <a href={`/es${pathWithoutLang}`} data-lang="es">
                  <img src={getFlagSrc('es')} alt="Español" width="20" height="15" loading="lazy" /> Español
                </a>
              </li>
              <li role="menuitem">
                <a href={`/en${pathWithoutLang}`} data-lang="en">
                  <img src={getFlagSrc('en')} alt="English" width="20" height="15" loading="lazy" /> English
                </a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- MAIN -->
    <main id="main-content">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="glass" style="margin-top: 4rem; text-align: center; font-size: 0.85rem;">
      <p>
        {common.footer.transparente}
        <a href="https://github.com/solarispkn/SolarisPKN-Labs" style="color: var(--border-cyan);">
          {common.footer.codigoAbierto}
        </a>
        — <span id="status">{common.footer.estado}</span>
      </p>
    </footer>

    <!-- ===== SCRIPTS ===== -->
<!-- ===== SCRIPTS (carga diferida) ===== -->
<script>
  // Scripts críticos que necesitan ejecutarse pronto (selector de idioma)
  import '@scripts/layout.js';
</script>

<!-- Scripts no críticos (scroll, canvas) se cargan después -->
<script defer>
  // Esto asegura que el script de scroll se cargue sin bloquear
  import '@scripts/scroll-animations.js';
  // El canvas (home-tech) se carga bajo demanda, no aquí
</script>
  </body>
</html>