---
// src/layouts/Layout.astro
export interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
}
const { title, description = "SolarisPKN - Laboratorio transparente de ingeniería", lang = 'es' } = Astro.props;

// Cargamos el archivo common.json del idioma correspondiente
const common = await import(`../locales/${lang}/common.json`);
const pathWithoutLang = Astro.url.pathname.replace(/^\/[a-z]{2}\//, '/');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title} | SolarisPKN Labs</title>
    <meta name="description" content={description} />
    <meta name="author" content="SolarisPKN" />
    <meta property="article:published_time" content="2026-06-13" />
    
    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:title" content={`${title} | SolarisPKN Labs`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://solarispkn.pages.dev" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SolarisPKN Labs" />
    <meta property="og:image" content="https://solarispkn.pages.dev/og-image.jpg" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | SolarisPKN Labs`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://solarispkn.pages.dev/og-image.jpg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/global.css" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="glass" style="position: sticky; top: 1rem; margin: 1rem; z-index: 100; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
      <div style="font-weight: bold; font-family: 'JetBrains Mono', monospace;">🌞 SolarisPKN</div>
      <nav style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
        <a href={`/${lang}/`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.inicio}</a>
		<a href={`/${lang}/under-construction`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.blog}</a>
		<a href={`/${lang}/under-construction`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.proyectos}</a>
        <a href={`/${lang}/arquitectura`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.arquitectura}</a>
        <a href={`/${lang}/portfolio`} style="color: var(--border-cyan); text-decoration: none;">{common.nav.portfolio}</a>
        <a href={`/${lang}/under-construction`} style="color: var(--accent-pink);">{common.nav.miCuenta}</a>
		<div class="language-dropdown" style="position: relative; margin-left: 0.5rem;">
<div class="language-selector">
  <button id="lang-btn" class="lang-btn" aria-haspopup="true" aria-expanded="false">
    <img src={`/images/flags/${lang === 'es' ? 'es' : 'en'}.svg`} alt={lang === 'es' ? 'Español' : 'English'} width="20" height="15">
    <span>{lang === 'es' ? 'Español' : 'English'}</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
  <ul id="lang-dropdown" class="lang-dropdown" role="menu" aria-labelledby="lang-btn">
    <li role="menuitem">
      <a href={`/es${pathWithoutLang}`} data-lang="es">
        <img src="/images/flags/es.svg" alt="Español" width="20" height="15"> Español
      </a>
    </li>
    <li role="menuitem">
      <a href={`/en${pathWithoutLang}`} data-lang="en">
        <img src="/images/flags/en.svg" alt="English" width="20" height="15"> English
      </a>
    </li>
  </ul>
</div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="glass" style="margin-top: 4rem; text-align: center; font-size: 0.85rem;">
      <p>{common.footer.transparente}<a href="https://github.com/solarispkn/solarispkn.github.io" style="color: var(--border-cyan);">{common.footer.codigoAbierto}</a> — <span id="status">{common.footer.estado}</span></p>
    </footer>
    <script is:inline src="/scripts/scroll-animations.js"></script>
	<script is:inline>
  // Language Selector Toggle
  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');

  if (langBtn && langDropdown) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown.classList.toggle('active');
      const expanded = langDropdown.classList.contains('active');
      langBtn.setAttribute('aria-expanded', expanded);
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!langBtn.contains(e.target)) {
        langDropdown.classList.remove('active');
        langBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
  </body>
</html>